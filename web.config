<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <security>
            <authorization>
                <remove users="*" roles="" verbs="" />
                <add accessType="Allow" roles="JYSK\ACL.BGDC FleetTracker.Administrators" />
                <add accessType="Allow" roles="JYSK\ACL.BGDC FleetTracker.Users" />
            </authorization>
        </security>
    </system.webServer>
</configuration>
